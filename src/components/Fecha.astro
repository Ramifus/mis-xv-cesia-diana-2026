---
// FechaEvento.astro
---

<section class="py-4 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <!-- Flores centrales arriba -->
    <div class="flex justify-center mb-8" id="flores-fecha">
      <img
        src="/imagenes/Separador.png"
        alt="Flores decorativas"
        class="w-40 md:w-56 lg:w-64 h-auto separador-dorado"
      />
    </div>

    <!-- Texto "Acompáñanos este día tan especial" -->
    <div class="mb-4" id="texto-invitacion-container">
      <div class="flex items-center justify-center px-4">
        <!-- TEXTO CENTRAL -->
        <div id="texto-invitacion">
          <p
            class="font-charm text-2xl sm:text-3xl md:text-4xl text-[#C9A646] italic leading-relaxed text-center"
          >
            Acompáñanos este día
          </p>
        </div>
      </div>
    </div>

    <!-- Fecha con líneas arriba y abajo -->
    <div class="relative max-w-md mx-auto" id="fecha-evento">
      <div class="flex items-center justify-center gap-4 md:gap-6">
        <!-- SÁBADO con líneas arriba y abajo - ANCHO FIJO -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#C9A646] mb-2"></div>
          <span
            class="font-charm text-xl md:text-lg text-[#ffffff] uppercase tracking-wider font-bold text-center"
            >SÁBADO</span
          >

          <div class="w-full h-px bg-[#C9A646] mt-2"></div>
        </div>

        <!-- Número 08 - CENTRADO -->
        <div
          class="flex items-center justify-center min-w-[80px] md:min-w-[100px]"
        >
          <span
            class="font-charm text-7xl md:text-8xl text-[#ffffff] font-bold -ml-1"
            >13</span
          >
        </div>

        <!-- NOVIEMBRE con líneas arriba y abajo - ANCHO FIJO -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#C9A646] mb-2"></div>
          <span
            class="font-charm text-xl md:text-lg text-[#ffffff] uppercase tracking-wider font-bold text-center"
            >JUNIO</span
          >
          <div class="w-full h-px bg-[#C9A646] mt-2"></div>
        </div>
      </div>

      <!-- Año - MOVIDO CON TRANSLATE -->
      <div class="mt-2 flex justify-center" id="anio-evento">
        <p
          class="font-charm text-3xl md:text-4xl text-[#ffffff] font-bold -translate-x-2"
        >
          2026
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("✨ Iniciando animaciones de fecha...");

      // 🎯 ESTADO INICIAL - Todo oculto
      gsap.set("#flores-fecha", { opacity: 0, scale: 0.8 });
      gsap.set("#texto-invitacion", { opacity: 0, scale: 0.9 });
      gsap.set("#fecha-evento", { opacity: 0, scale: 0.9 });
      gsap.set("#anio-evento", { opacity: 0, scale: 0.9 });

      // ✨ ANIMACIÓN SIMULTÁNEA - TODO AL MISMO TIEMPO
      ScrollTrigger.create({
        trigger: "#flores-fecha",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => {
          const tl = gsap.timeline();

          // TODO aparece al mismo tiempo
          tl.to(
            "#flores-fecha, #texto-invitacion, #fecha-evento, #anio-evento",
            {
              opacity: 1,
              duration: 1,
              ease: "power2.out",
            },
          )
            .to(
              "#flores-fecha",
              {
                scale: 1,
                duration: 1,
                ease: "back.out(1.4)",
              },
              "<",
            )
            .to(
              "#texto-invitacion, #fecha-evento, #anio-evento",
              {
                scale: 1,
                duration: 1,
                ease: "back.out(1.2)",
              },
              "<",
            );
        },
        onLeaveBack: () => {
          // Resetear todo al salir por arriba - SIMULTÁNEO
          const tl = gsap.timeline();

          tl.to(
            "#flores-fecha, #texto-invitacion, #fecha-evento, #anio-evento",
            {
              opacity: 0,
              duration: 0.5,
              ease: "power2.in",
            },
          )
            .to(
              "#flores-fecha",
              {
                scale: 0.8,
                duration: 0.5,
                ease: "power2.in",
              },
              "<",
            )
            .to(
              "#texto-invitacion, #fecha-evento, #anio-evento",
              {
                scale: 0.9,
                duration: 0.5,
                ease: "power2.in",
              },
              "<",
            );
        },
      });

      console.log("🎉 Animaciones de fecha listas!");
    });
  }
</script>
